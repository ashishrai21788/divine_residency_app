{
  "info": {
    "name": "Villa Society Management API",
    "description": "NestJS backend for Villa Society: auth, societies, villas, floors, gates, guards, visitors, deliveries, billing, SOS, complaints, notices, expenses, staff, reports. Use {{baseUrl}}/api as base. Set accessToken after login (Auth → Login).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "society_id", "value": "" },
    { "key": "villa_id", "value": "" },
    { "key": "floor_id", "value": "" },
    { "key": "gate_id", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "visitor_id", "value": "" },
    { "key": "delivery_id", "value": "" },
    { "key": "billing_id", "value": "" },
    { "key": "complaint_id", "value": "" },
    { "key": "notice_id", "value": "" },
    { "key": "blacklist_id", "value": "" },
    { "key": "guard_id", "value": "" },
    { "key": "staff_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Login (email/username/mobile + password), change password, refresh token, profile. Login and Refresh Token do not require Bearer.",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Admin: email + password. Guard: username + password. Resident: mobile + password. Saves accessToken to collection variable for other requests.",
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 201 || pm.response.code === 200) {",
                    "    const json = pm.response.json();",
                    "    if (json.accessToken) {",
                    "        pm.collectionVariables.set('accessToken', json.accessToken);",
                    "        if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                    "    }",
                    "}"
                  ],
                  "type": "text/javascript"
                }
              }
            ]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/refresh-token"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpassword123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/change-password"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/profile"
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
