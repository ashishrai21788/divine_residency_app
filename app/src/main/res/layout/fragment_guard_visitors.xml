<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data class="FragmentGuardVisitorsBinding" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/villa_bg_page"
        android:orientation="vertical">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/guard_visitors_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/villa_surface"
            android:elevation="2dp"
            app:tabGravity="fill"
            app:tabIndicatorColor="@color/villa_primary"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed"
            app:tabSelectedTextColor="@color/villa_primary"
            app:tabTextColor="@color/villa_text_secondary" />

        <LinearLayout
            android:id="@+id/guard_offline_queue_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/villa_tag_bg_pending"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/villa_padding_standard"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/guard_offline_queue_banner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/villa_tag_text_pending"
                android:textSize="13sp"
                tools:text="2 visitor entries pending sync" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/guard_sync_now_button"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sync now"
                android:textColor="@color/villa_primary" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ScrollView
                android:id="@+id/guard_add_visitor_form"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/villa_padding_standard"
                    app:cardBackgroundColor="@color/villa_surface"
                    app:cardCornerRadius="@dimen/villa_card_corner"
                    app:cardElevation="@dimen/villa_card_elevation"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/villa_padding_standard">

                        <TextView
                            style="@style/VillaSection.Header"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Register visitor" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/VillaTextInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:hint="Name"
                            app:boxBackgroundColor="@color/villa_surface">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/add_visitor_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName"
                                android:textColor="@color/villa_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/VillaTextInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:hint="Phone"
                            app:boxBackgroundColor="@color/villa_surface">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/add_visitor_phone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="phone"
                                android:textColor="@color/villa_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/VillaTextInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:hint="Villa / unit"
                            app:boxBackgroundColor="@color/villa_surface">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/add_visitor_villa"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textColor="@color/villa_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/VillaTextInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:hint="Floor"
                            app:boxBackgroundColor="@color/villa_surface">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/add_visitor_floor"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textColor="@color/villa_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/VillaTextInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:hint="Purpose"
                            app:boxBackgroundColor="@color/villa_surface">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/add_visitor_purpose"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textColor="@color/villa_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/VillaTextInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:hint="Vehicle number (optional)"
                            app:boxBackgroundColor="@color/villa_surface">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/add_visitor_vehicle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textColor="@color/villa_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/add_visitor_submit"
                            style="@style/VillaButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="Submit visitor" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </ScrollView>

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/guard_visitor_logs_swipe"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/guard_visitor_logs_list"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:padding="@dimen/villa_padding_standard" />

                    <include
                        android:id="@+id/guard_visitor_logs_empty"
                        layout="@layout/view_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone" />
                </FrameLayout>
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
        </FrameLayout>
    </LinearLayout>
</layout>
