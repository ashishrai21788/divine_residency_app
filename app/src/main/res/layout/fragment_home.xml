<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data class="HomeFragmentBinding" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/villa_bg_page"
        android:fitsSystemWindows="true">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="88dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/villa_padding_standard">

                <!-- Welcome card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/villa_surface"
                    app:cardCornerRadius="@dimen/villa_card_corner"
                    app:cardElevation="@dimen/villa_card_elevation"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/villa_padding_standard">

                        <TextView
                            android:id="@+id/home_avatar_initial"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_avatar_circle"
                            android:gravity="center"
                            android:text="R"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/villa_padding_standard"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/home_welcome_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Welcome"
                                android:textColor="@color/villa_text_secondary"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/home_user_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="@color/villa_text_primary"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/home_villa_floor"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/villa_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/home_sos_button"
                            style="@style/Widget.MaterialComponents.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="16dp"
                            android:text="SOS"
                            android:textAllCaps="false"
                            android:textSize="13sp"
                            app:backgroundTint="@color/villa_sos_red"
                            app:cornerRadius="20dp" />

                        <ImageView
                            android:id="@+id/home_profile_icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_elevated_card"
                            android:contentDescription="Profile"
                            android:padding="8dp"
                            android:visibility="gone"
                            app:srcCompat="@android:drawable/ic_menu_my_calendar" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/villa_section_spacing">

                    <LinearLayout
                        android:id="@+id/home_loading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:background="@color/villa_shimmer" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:layout_marginTop="16dp"
                            android:background="@color/villa_shimmer" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:layout_marginTop="16dp"
                            android:background="@color/villa_shimmer" />
                    </LinearLayout>

                    <include
                        android:id="@+id/home_error"
                        layout="@layout/view_error_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/home_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            style="@style/VillaSection.Header"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingTop="@dimen/villa_padding_small"
                            android:paddingBottom="@dimen/villa_padding_small"
                            android:text="Pending visitors" />

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/villa_surface"
                            app:cardCornerRadius="@dimen/villa_card_corner"
                            app:cardElevation="@dimen/villa_card_elevation"
                            app:cardUseCompatPadding="true">

                            <LinearLayout
                                android:id="@+id/home_pending_visitors_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/villa_padding_standard">

                                <include
                                    android:id="@+id/home_pending_visitors_empty"
                                    layout="@layout/view_empty_state"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content" />

                                <LinearLayout
                                    android:id="@+id/home_pending_visitors_list"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <TextView
                            style="@style/VillaSection.Header"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingTop="@dimen/villa_section_spacing"
                            android:paddingBottom="@dimen/villa_padding_small"
                            android:text="Current bill" />

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/villa_surface"
                            app:cardCornerRadius="@dimen/villa_card_corner"
                            app:cardElevation="@dimen/villa_card_elevation"
                            app:cardUseCompatPadding="true">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/villa_padding_standard">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:id="@+id/home_bill_month"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:textColor="@color/villa_text_secondary"
                                        android:textSize="14sp" />

                                    <TextView
                                        android:id="@+id/home_bill_status"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:background="@drawable/bg_status_chip_default"
                                        android:paddingHorizontal="12dp"
                                        android:paddingVertical="4dp"
                                        android:textColor="@color/villa_tag_text_default"
                                        android:textSize="12sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <TextView
                                    android:id="@+id/home_bill_total"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="sans-serif-medium"
                                    android:textColor="@color/villa_text_primary"
                                    android:textSize="24sp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:orientation="horizontal">

                                    <TextView
                                        android:id="@+id/home_bill_paid"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:textColor="@color/villa_text_secondary"
                                        android:textSize="12sp" />

                                    <TextView
                                        android:id="@+id/home_bill_pending"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textColor="@color/villa_text_secondary"
                                        android:textSize="12sp" />
                                </LinearLayout>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/home_bill_view_details"
                                    style="@style/VillaButton.Secondary"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="12dp"
                                    android:text="View details" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <TextView
                            style="@style/VillaSection.Header"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingTop="@dimen/villa_section_spacing"
                            android:paddingBottom="@dimen/villa_padding_small"
                            android:text="Recent deliveries" />

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="@color/villa_surface"
                            app:cardCornerRadius="@dimen/villa_card_corner"
                            app:cardElevation="@dimen/villa_card_elevation"
                            app:cardUseCompatPadding="true">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="@dimen/villa_padding_standard">

                                <LinearLayout
                                    android:id="@+id/home_deliveries_list"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical" />

                                <include
                                    android:id="@+id/home_deliveries_empty"
                                    layout="@layout/view_empty_state"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:visibility="gone" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <TextView
                            style="@style/VillaSection.Header"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingTop="@dimen/villa_section_spacing"
                            android:paddingBottom="@dimen/villa_padding_small"
                            android:text="Notices" />

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingBottom="16dp"
                            android:scrollbars="none">

                            <LinearLayout
                                android:id="@+id/home_notices_list"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingEnd="16dp" />
                        </HorizontalScrollView>
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
