<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data class="FragmentResidentBillingBinding" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/villa_bg_page"
        android:orientation="vertical">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/billing_swipe"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/villa_padding_standard">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/villa_surface"
                        app:cardCornerRadius="@dimen/villa_card_corner"
                        app:cardElevation="@dimen/villa_card_elevation"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/villa_padding_standard">

                            <TextView
                                style="@style/VillaSection.Header"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Billing summary" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Total"
                                        android:textColor="@color/villa_text_secondary"
                                        android:textSize="12sp" />

                                    <TextView
                                        android:id="@+id/billing_total"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-medium"
                                        android:textColor="@color/villa_text_primary"
                                        android:textSize="18sp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Paid"
                                        android:textColor="@color/villa_text_secondary"
                                        android:textSize="12sp" />

                                    <TextView
                                        android:id="@+id/billing_paid"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-medium"
                                        android:textColor="@color/villa_tag_text_approved"
                                        android:textSize="18sp" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Pending"
                                        android:textColor="@color/villa_text_secondary"
                                        android:textSize="12sp" />

                                    <TextView
                                        android:id="@+id/billing_pending"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="sans-serif-medium"
                                        android:textColor="@color/villa_tag_text_pending"
                                        android:textSize="18sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:id="@+id/billing_due_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textColor="@color/villa_text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/billing_status_pill"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_status_chip_default"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="5dp"
                                android:textColor="@color/villa_tag_text_default"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        style="@style/VillaSection.Header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="@dimen/villa_section_spacing"
                        android:paddingBottom="@dimen/villa_padding_small"
                        android:text="Bills" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/villa_surface"
                        app:cardCornerRadius="@dimen/villa_card_corner"
                        app:cardElevation="@dimen/villa_card_elevation"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/villa_padding_small">

                            <LinearLayout
                                android:id="@+id/billing_bills_list"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />

                            <include
                                android:id="@+id/billing_bills_empty"
                                layout="@layout/view_empty_state"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:visibility="gone" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        style="@style/VillaSection.Header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="@dimen/villa_section_spacing"
                        android:paddingBottom="@dimen/villa_padding_small"
                        android:text="Payment history" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@color/villa_surface"
                        app:cardCornerRadius="@dimen/villa_card_corner"
                        app:cardElevation="@dimen/villa_card_elevation"
                        app:cardUseCompatPadding="true">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/villa_padding_small">

                            <LinearLayout
                                android:id="@+id/billing_payments_list"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical" />

                            <include
                                android:id="@+id/billing_payments_empty"
                                layout="@layout/view_empty_state"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:visibility="gone" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <include
                        android:id="@+id/billing_error"
                        layout="@layout/view_error_view"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/villa_padding_standard"
                        android:visibility="gone" />

                    <ProgressBar
                        android:id="@+id/billing_loading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="24dp"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>
</layout>
