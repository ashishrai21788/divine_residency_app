<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data class="FragmentResidentComplaintsBinding" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/villa_bg_page"
        android:orientation="vertical">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/complaints_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/villa_surface"
            android:elevation="2dp"
            app:tabGravity="fill"
            app:tabIndicatorColor="@color/villa_primary"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed"
            app:tabSelectedTextColor="@color/villa_primary"
            app:tabTextColor="@color/villa_text_secondary" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/complaints_swipe"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.core.widget.NestedScrollView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/villa_padding_standard">

                        <LinearLayout
                            android:id="@+id/complaints_list_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                        <include
                            android:id="@+id/complaints_empty"
                            layout="@layout/view_empty_state"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                        <include
                            android:id="@+id/complaints_error"
                            layout="@layout/view_error_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.core.widget.NestedScrollView>
            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <ScrollView
                android:id="@+id/complaints_form_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:visibility="gone">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/villa_padding_standard"
                    app:cardBackgroundColor="@color/villa_surface"
                    app:cardCornerRadius="@dimen/villa_card_corner"
                    app:cardElevation="@dimen/villa_card_elevation"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/villa_padding_standard">

                        <TextView
                            style="@style/VillaSection.Header"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Raise a complaint" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Category"
                            android:textColor="@color/villa_text_secondary"
                            android:textSize="13sp" />

                        <Spinner
                            android:id="@+id/complaint_category"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_elevated_card"
                            android:padding="8dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/VillaTextInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            app:boxBackgroundColor="@color/villa_surface"
                            android:hint="Short title">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/complaint_title"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textCapSentences"
                                android:textColor="@color/villa_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/VillaTextInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:boxBackgroundColor="@color/villa_surface"
                            android:hint="Describe the issue">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/complaint_description"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="top"
                                android:inputType="textMultiLine|textCapSentences"
                                android:minLines="4"
                                android:textColor="@color/villa_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/complaint_submit"
                            style="@style/VillaButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="Submit complaint" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </ScrollView>
        </FrameLayout>

        <ProgressBar
            android:id="@+id/complaints_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </LinearLayout>
</layout>
