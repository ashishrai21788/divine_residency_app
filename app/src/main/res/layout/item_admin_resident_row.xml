<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/villa_padding_small"
    android:background="@drawable/bg_elevated_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/villa_padding_standard">

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="@null"
        app:srcCompat="@drawable/ic_profile"
        app:tint="@color/villa_primary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/villa_padding_standard"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/resident_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/villa_text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/resident_role"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/villa_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/resident_contact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/villa_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
