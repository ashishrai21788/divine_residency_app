<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="12dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_elevated_card"
            android:contentDescription="@null"
            android:padding="8dp"
            app:srcCompat="@drawable/ic_tile_local_shipping"
            app:tint="@color/villa_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/delivery_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/villa_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/delivery_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/villa_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/delivery_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_chip_default"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:textColor="@color/villa_tag_text_default"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</layout>
