<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="BottomNavigationViewStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconSize">24dp</item>
        <item name="itemTextAppearanceActive">@style/BottomNavTextActive</item>
        <item name="itemTextAppearanceInactive">@style/BottomNavTextInactive</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="BottomNavTextActive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/villa_primary</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="BottomNavTextInactive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/villa_nav_inactive</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="VillaButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/villa_primary</item>
        <item name="cornerRadius">@dimen/villa_button_corner</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="VillaButton.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/villa_primary</item>
        <item name="strokeColor">@color/villa_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">@dimen/villa_button_corner</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="VillaTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/villa_input_stroke_selector</item>
        <item name="hintTextColor">@color/villa_text_hint</item>
        <item name="boxCornerRadiusTopStart">@dimen/villa_radius_input</item>
        <item name="boxCornerRadiusTopEnd">@dimen/villa_radius_input</item>
        <item name="boxCornerRadiusBottomStart">@dimen/villa_radius_input</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/villa_radius_input</item>
        <item name="android:textColorHint">@color/villa_text_hint</item>
    </style>

    <style name="VillaCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/villa_card_corner</item>
        <item name="cardElevation">@dimen/villa_card_elevation</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardBackgroundColor">@color/villa_surface</item>
    </style>

    <style name="VillaSection.Header" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/villa_text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Villa.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/villa_text_primary</item>
    </style>

    <style name="TextAppearance.Villa.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/villa_text_secondary</item>
    </style>
</resources>
