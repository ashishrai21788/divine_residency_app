<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.DRWA" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/villa_primary</item>
        <item name="colorPrimaryVariant">@color/villa_primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/villa_primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/villa_surface</item>
        <item name="colorOnSurface">@color/villa_text_primary</item>
        <item name="android:colorBackground">@color/villa_bg_page</item>
        <item name="colorOnBackground">@color/villa_text_primary</item>
        <item name="android:statusBarColor">@color/villa_surface</item>
        <item name="android:navigationBarColor">@color/villa_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="materialButtonStyle">@style/VillaButton</item>
        <item name="textInputStyle">@style/VillaTextInput</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
    </style>

    <style name="Theme.DRWA.Splash" parent="Theme.DRWA">
        <item name="android:statusBarColor">@color/villa_splash_bg</item>
        <item name="android:navigationBarColor">@color/villa_splash_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>
</resources>
