<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Block cleartext by default (production) -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <!-- Allow cleartext only for localhost / emulator (development) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.0.3.2</domain>
        <!-- Physical device → PC over HTTP: set HOST_ORIGIN in VillaSocietyConfig to e.g. http://192.168.1.8:3000 and add that host here:
        <domain includeSubdomains="true">192.168.1.8</domain>
        -->
    </domain-config>
</network-security-config>
