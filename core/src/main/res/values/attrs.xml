<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="HorizontalCounter">
        <attr name="stepValue" format="string" />
        <attr name="initialValue" format="string" />
        <attr name="maxValue" format="string" />
        <attr name="minValue" format="string" />
        <attr name="plusButtonColor" format="color" />
        <attr name="minusButtonColor" format="color" />
        <attr name="plusIcon" format="reference" />
        <attr name="minusIcon" format="reference" />
        <attr name="textColor" format="color" />
        <attr name="isSmallView" format="boolean" />
        <attr name="textSize" format="dimension" />
        <attr name="displayAsInteger" format="boolean" />
        <attr name="isEditable" format="boolean" />
        <attr name="isDisplayOnly" format="boolean" />
    </declare-styleable>


    <declare-styleable name="advDrawerLayout">
        <attr name="adl_customBehavior" format="boolean" />
        <attr name="adl_viewScale" format="float" />
        <attr name="adl_viewScrimColor" format="color" />
        <attr name="adl_viewElevation" format="dimension" />
        <attr name="adl_drawerElevation" format="dimension" />
    </declare-styleable>


    <declare-styleable name="CoreCurrencyEditText">
        <attr name="allow_negative_values" format="boolean" />
        <attr name="decimal_digits" format="integer" />
    </declare-styleable>


    <declare-styleable name="CoreRating">

        <attr name="starWidth" format="dimension" />

        <attr name="starHeight" format="dimension" />

        <attr name="maxStar" format="integer" />

        <attr name="minStar" format="float" />

        <attr name="currentStar" format="float" />

        <attr name="padding" format="dimension" />

        <attr name="emptyStar" format="reference" />

        <attr name="fullStar" format="reference" />

        <attr name="halfStar" format="reference" />

        <attr name="canChange" format="boolean" />

        <attr name="fillColor" format="integer" />
        <attr name="emptyColor" format="integer" />
        <!-- <attr name="iconSize" format="integer" />-->


    </declare-styleable>


    <declare-styleable name="CoreSwipeRevealLayout">
        <attr name="dragEdge">
            <flag name="left" value="1" />
            <flag name="right" value="2" />
            <flag name="top" value="4" />
            <flag name="bottom" value="8" />
        </attr>

        <attr name="mode">
            <enum name="normal" value="0" />
            <enum name="same_level" value="1" />
        </attr>

        <attr name="flingVelocity" format="integer" />

        <attr name="minDistRequestDisallowParent" format="dimension" />
    </declare-styleable>

    <declare-styleable name="CoreCircleImageView">
        <attr name="civ_border_width" format="dimension" />
        <attr name="civ_border_color" format="color" />
        <attr name="civ_border_overlay" format="boolean" />
        <attr name="civ_circle_background_color" format="color" />
    </declare-styleable>

    <declare-styleable name="CoreRangeSeekBar">
        <attr name="coreMinValue" format="float" />
        <attr name="coreMaxValue" format="float" />
        <attr name="coreStepValue" format="float" />
        <attr name="valueType">
            <enum name="intType" value="6" />
            <enum name="floatType" value="7" />
        </attr>

        <!-- ready -->
        <attr name="enableGradient" format="boolean" />
        <attr name="coreTextColor" format="color" />

        <attr name="showThumbsText">
            <enum name="none" value="0" />
            <enum name="below" value="1" />
            <enum name="above" value="2" />
            <enum name="center" value="3" />
        </attr>

        <attr name="thumbsTextMargin" format="dimension" />
        <attr name="additionalTextMargin" format="dimension" />

        <attr name="showAdditionalText">
            <enum name="none" value="0" />
            <enum name="below" value="1" />
            <enum name="above" value="2" />
            <enum name="center" value="3" />
        </attr>

        <attr name="roundedCorners" format="boolean" />
        <attr name="barHeight" format="dimension" />

        <attr name="active" format="boolean" />

        <attr name="textFont" format="reference" />
        <attr name="coreTextSize" format="dimension" />

        <attr name="centerText" format="string" />
        <attr name="rightText" format="string" />
        <attr name="leftText" format="string" />

        <attr name="thumbsNormal" format="reference" />
        <attr name="thumbsPressed" format="reference" />
        <attr name="thumbsDisabled" format="reference" />

        <attr name="sideColor" format="color" />
        <attr name="transitionColor" format="color" />
        <attr name="centerColor" format="color" />
    </declare-styleable>



    <!-- Common attributes -->
    <attr name="corner_radius" format="float" />
    <attr name="min_value" format="float" />
    <attr name="max_value" format="float" />
    <attr name="min_start_value" format="float" />
    <attr name="max_start_value" format="float" />
    <attr name="steps" format="float" />
    <attr name="gap" format="float" />
    <attr name="fix_gap" format="float" />
    <attr name="bar_color_mode" format="enum">
        <enum name="solid" value="0" />
        <enum name="gradient" value="1" />
    </attr>
    <attr name="bar_color" format="color" />
    <attr name="bar_gradient_start" format="color" />
    <attr name="bar_gradient_end" format="color" />
    <attr name="bar_highlight_color_mode" format="enum">
        <enum name="solid" value="0" />
        <enum name="gradient" value="1" />
    </attr>
    <attr name="bar_highlight_color" format="color" />
    <attr name="bar_highlight_gradient_start" format="color" />
    <attr name="bar_highlight_gradient_end" format="color" />
    <attr name="thumb_diameter" format="dimension"/>
    <attr name="position" format="enum">
        <enum name="left" value="0" />
        <enum name="right" value="1" />
    </attr>
    <attr name="data_type" format="enum">
        <enum name="_long" value="0" />
        <enum name="_double" value="1" />
        <enum name="_integer" value="2" />
        <enum name="_float" value="3" />
        <enum name="_short" value="4" />
        <enum name="_byte" value="5" />
    </attr>
    <attr name="bar_height" format="dimension"/>
    <attr name="seek_bar_touch_enabled" format="boolean" />

    <!-- Seekbar -->
    <declare-styleable name="CrystalSeekbar" >
        <attr name="corner_radius" />
        <attr name="min_value" />
        <attr name="max_value" />
        <attr name="min_start_value" />
        <attr name="max_start_value" />
        <attr name="steps" />
        <attr name="gap" />
        <attr name="fix_gap" />
        <attr name="bar_height" />
        <attr name="bar_color_mode" />
        <attr name="bar_color" />
        <attr name="bar_gradient_start" />
        <attr name="bar_gradient_end" />
        <attr name="bar_highlight_color_mode" />
        <attr name="bar_highlight_color" />
        <attr name="bar_highlight_gradient_start" />
        <attr name="bar_highlight_gradient_end" />
        <attr name="thumb_diameter" />
        <attr name="position" />
        <attr name="data_type" />
        <attr name="thumb_color" format="color" />
        <attr name="thumb_color_pressed" format="color" />
        <attr name="thumb_image" format="reference" />
        <attr name="thumb_image_pressed" format="reference" />
        <attr name="seek_bar_touch_enabled" />
    </declare-styleable>

    <!-- Range Seekbar -->
    <declare-styleable name="CrystalRangeSeekbar" >
        <attr name="corner_radius" />
        <attr name="min_value" />
        <attr name="max_value" />
        <attr name="min_start_value" />
        <attr name="max_start_value" />
        <attr name="steps" />
        <attr name="gap" />
        <attr name="fix_gap" />
        <attr name="bar_height"/>
        <attr name="bar_color_mode" />
        <attr name="bar_color" />
        <attr name="bar_gradient_start" />
        <attr name="bar_gradient_end" />
        <attr name="bar_highlight_color_mode" />
        <attr name="bar_highlight_color" />
        <attr name="bar_highlight_gradient_start" />
        <attr name="bar_highlight_gradient_end" />
        <attr name="thumb_diameter" />
        <attr name="position" />
        <attr name="data_type" />
        <attr name="left_thumb_color" format="color" />
        <attr name="left_thumb_color_pressed" format="color" />
        <attr name="left_thumb_image" format="reference" />
        <attr name="left_thumb_image_pressed" format="reference" />
        <attr name="right_thumb_color" format="color" />
        <attr name="right_thumb_color_pressed" format="color" />
        <attr name="right_thumb_image" format="reference" />
        <attr name="right_thumb_image_pressed" format="reference" />
        <attr name="seek_bar_touch_enabled" />
    </declare-styleable>


    <declare-styleable name="ZoomageView">
        <attr name="zoomage_zoomable" format="boolean" />
        <attr name="zoomage_translatable" format="boolean" />
        <attr name="zoomage_restrictBounds" format="boolean" />
        <attr name="zoomage_animateOnReset" format="boolean" />
        <attr name="zoomage_doubleTapToZoom" format="boolean" />
        <attr name="zoomage_doubleTapToZoomScaleFactor" format="float" />
        <attr name="zoomage_autoCenter" format="boolean" />
        <attr name="zoomage_minScale" format="float" />
        <attr name="zoomage_maxScale" format="float" />
        <attr name="zoomage_autoResetMode" format="enum">
            <enum name="UNDER" value="0" />
            <enum name="OVER" value="1" />
            <enum name="ALWAYS" value="2" />
            <enum name="NEVER" value="3" />
        </attr>
    </declare-styleable>


    <declare-styleable name="CoreAutoScrollCircularPagerView">
        <attr name="unselected_dot_color" format="color" />
        <attr name="selected_dot_color" format="color" />
        <attr name="auto_scroll_delay" format="integer" />
        <attr name="is_auto_scroll" format="boolean" />
        <attr name="dot_margin" format="dimension" />
        <attr name="dot_gravity" format="enum">
            <enum name="bottom" value="0"/>
            <enum name="top" value="1"/>
        </attr>
    </declare-styleable>

</resources>